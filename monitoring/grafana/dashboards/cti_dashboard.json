{
  "uid": "cti-mlops",
  "title": "CTI Bot — MLOps Monitoring",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "HTTP Request Rate (req/s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(cti_http_requests_total[2m])) by (endpoint)",
          "legendFormat": "{{endpoint}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "HTTP Latency p95 (seconds)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(cti_http_request_duration_seconds_bucket[2m])) by (le, endpoint))",
          "legendFormat": "p95 {{endpoint}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "RAG Pipeline Duration p95 (seconds)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(cti_rag_duration_seconds_bucket[2m])) by (le, source_filter))",
          "legendFormat": "p95 filter={{source_filter}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "LLM Generation Duration p95 (seconds)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(cti_llm_duration_seconds_bucket[2m])) by (le))",
          "legendFormat": "LLM p95"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "fixed", "fixedColor": "orange" } }
      }
    },
    {
      "id": 5,
      "type": "gauge",
      "title": "Advisory Freshness (hours since last ingest)",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 16 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "cti_advisory_freshness_hours",
          "legendFormat": "Hours stale"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 12 },
              { "color": "red", "value": 24 }
            ]
          },
          "min": 0,
          "max": 72
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Hallucination Score (median — higher is better)",
      "gridPos": { "h": 8, "w": 9, "x": 6, "y": 16 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.5, sum(rate(cti_hallucination_score_bucket[5m])) by (le))",
          "legendFormat": "median faithfulness score"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.6 },
              { "color": "green", "value": 0.8 }
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Avg Chunks Retrieved per Query",
      "gridPos": { "h": 8, "w": 9, "x": 15, "y": 16 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.5, sum(rate(cti_chunks_retrieved_bucket[2m])) by (le))",
          "legendFormat": "median chunks"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "purple" } }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Ingestion Duration (seconds)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(cti_ingestion_duration_seconds_bucket[10m])) by (le))",
          "legendFormat": "ingestion p95"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "fixed", "fixedColor": "blue" } }
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Chunks Ingested (total rate)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(cti_ingestion_chunks_total[5m])) by (source_file)",
          "legendFormat": "{{source_file}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } }
      }
    }
  ]
}
